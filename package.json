{
	"name": "apple-rag-mcp",
	"version": "4.18.4",
	"private": true,
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=22.16.0",
		"pnpm": ">=9.0.0"
	},
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"deploy": "pnpm build && wrangler d1 migrations apply apple-rag-db --remote && wrangler deploy",
		"deploy:dev": "pnpm build && wrangler deploy --env development",
		"lint": "biome check --write .",
		"typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p worker/tsconfig.json",
		"check": "pnpm lint && pnpm typecheck",
		"db:setup:local": "wrangler d1 execute apple-rag-db --local --file=./migrations/schema.sql",
		"db:setup:remote": "wrangler d1 execute apple-rag-db --remote --file=./migrations/schema.sql"
	},
	"dependencies": {
		"@headlessui/react": "^2.2.9",
		"@hono/swagger-ui": "^0.5.2",
		"@hono/zod-openapi": "^1.0.2",
		"@hookform/resolvers": "^5.1.1",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-label": "^2.1.7",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@react-three/fiber": "^9.4.0",
		"@stripe/react-stripe-js": "^3.7.0",
		"@stripe/stripe-js": "^7.5.0",
		"@tabler/icons-react": "^3.34.1",
		"apexcharts": "^5.3.2",
		"axios": "^1.10.0",
		"bcryptjs": "^3.0.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"gsap": "^3.13.0",
		"hono": "^4.12.8",
		"i18next": "^25.8.18",
		"motion": "^12.37.0",
		"postgres": "^3.4.7",
		"react": "^19.2.4",
		"react-apexcharts": "^1.7.0",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.60.0",
		"react-hot-toast": "^2.6.0",
		"react-i18next": "^16.5.8",
		"react-router-dom": "^7.13.1",
		"react-syntax-highlighter": "^15.6.1",
		"resend": "^4.8.0",
		"simplex-noise": "^4.0.3",
		"stripe": "^18.4.0",
		"swr": "^2.3.4",
		"tailwind-merge": "^3.5.0",
		"three": "^0.181.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@cloudflare/vite-plugin": "^1.29.0",
		"@cloudflare/workers-types": "^4.20260317.1",
		"@tailwindcss/vite": "^4.2.1",
		"@types/bcryptjs": "^3.0.0",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@types/three": "^0.181.0",
		"@vitejs/plugin-react": "^6.0.1",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.3.6",
		"typescript": "^5.9.3",
